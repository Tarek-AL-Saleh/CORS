# ============================================================
# CORS Backend — Environment Variables Example
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to version control.
# ============================================================


# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://<username>:<password>@localhost:5432/cors_db


# ----------------------------------------------------------
# Authentication / Security
# ----------------------------------------------------------
# A long, random secret used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-me

# Default admin credentials created on first startup.
# Change these immediately in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
ADMIN_EMAIL=admin@example.com


# ----------------------------------------------------------
# CORS / Frontend
# ----------------------------------------------------------
# The URL of the frontend application that is allowed to make
# cross-origin requests. Use http://localhost:5173 for local dev.
FRONTEND_URL=http://localhost:5173


# ----------------------------------------------------------
# Email (SendGrid)
# ----------------------------------------------------------
# Required for password-reset and notification emails.
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=no-reply@example.com


# ----------------------------------------------------------
# Runtime Flags
# ----------------------------------------------------------
# Set to "true" to drop and recreate all database tables on startup.
# WARNING: This will permanently delete all data. Use only in dev.
FORCE_DB_RESET=false
